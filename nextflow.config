// nextflow.config

// ================== Profiles ==================
profiles {

    // --- Containerized execution ---
    container {
        process {
            container = 'docker://myorg/mypipeline:latest'
        }
	singularity {
		enabled    = true
		autoMounts = true
		// Dynamically add binds for spec_bin and license
		runOptions = [
			params.spec_bin  ? "--bind ${new File(params.spec_bin).parent}" : '',
			params.license   ? "--bind ${new File(params.license).parent}"  : ''
		].findAll { it }  // remove empty strings
		.join(' ')
        }
    }

    // --- Host execution (modules, no containers) ---
    host {
        process {
            container = null
        }
    }
}

process {

        withLabel: 'random_sampling' {
		executor = 'local'
		// cpus = params.random_sampling_cpus ?: 4
		cpus = 4
		memory = '4 GB'
		time = '03:00:00'
		errorStrategy = 'retry'
                // memory = params.random_sampling_memory ?: '4 GB'
                // time = params.random_sampling_time ?: '03:00:00'
                // errorStrategy = 'retry'
        }

        executor = 'slurm'

        withLabel: 'SN_nf_pulsar' {
                queue = params.SN_nf_pulsar_queue  ?: 'k2-hipri,k2-fmipr'
                cpus = params.SN_nf_pulsar_cpus  ?: 64
                memory = params.SN_nf_pulsar_memory  ?: '128 GB'
                time = params.SN_nf_pulsar_time  ?: '3:00:00'
                errorStrategy = 'retry'
		maxRetries = 50
		retryDelay = '5m'
        }

        withLabel: 'SN_nf_combine_psar' {
                queue = params.SN_nf_combine_psar_queue ?: 'k2-hipri,k2-fmipr'
                cpus = params.SN_nf_combine_psar_cpus ?: 6
                memory = params.SN_nf_combine_psar_memory ?: '300 GB'
                time = params.SN_nf_combine_psar_time ?: '72:00:00'
                errorStrategy = 'retry'
		maxRetries = 50
                retryDelay = '5m'
        }

        withLabel: 'SN_nf_dia_search' {
                queue = params.SN_nf_dia_search_queue ?: 'k2-hipri,k2-fmipr'
                cpus = params.SN_nf_dia_search_cpus ?: 64
                memory = params.SN_nf_dia_search_memory ?: '128 GB'
                time = params.SN_nf_dia_search_time ?: '03:00:00'
                errorStrategy = 'retry'
		maxRetries = 50
	        retryDelay = '5m'
        }

        withLabel: 'SN_nf_combine_sne' {
                queue = params.SN_nf_combine_sne_queue ?: 'k2-hipri,k2-fmipr'
                cpus = params.SN_nf_combine_sne_cpus ?: 8
                memory = params.SN_nf_combine_sne_memory ?: '128 GB'
                time = params.SN_nf_combine_sne_time ?: '72:00:00'
                errorStrategy = 'retry'
		maxRetries = 50
                retryDelay = '5m'
        }
}

executor {
	queueSize = params.executor_queueSize ?: 4
	submitRateLimit = '1/5sec'
}

params {
	// dotnet_module = System.getenv('DOTNET_MODULE') ?: 'dotnet/10.0.2'
        SPEC_VER= "19.8.250311.62635"
        license = new File('/users/3054755/license/spec_license_no_var.txt').text.readLines()[0]
        spec_bin = "/users/3054755/bin/spectronaut/Spectronaut_$SPEC_VER/binaries/Spectronaut/bin/SpectronautCMD.dll"
	
	def timestamp = new Date().format("yyMMdd_HHmmss")
	
	params.log_dir = "${launchDir}/logs/${timestamp}"
	new File(params.log_dir).mkdirs()	
	
	rawfile_dir = "${launchDir}/raw_d"
	intermediates_output = "${launchDir}/intermediates"
	intermediate_psar = "${params.intermediates_output}/libs"
	lib_output = "${launchDir}/out_lib"
	dia_output = "${launchDir}/out_dia"
	tmp_dir = "${launchDir}/tmp"
	psar_lib = "${params.lib_output}/libs"
	
	JOB_NAME = "250613_THP1_MZ1_1034s_dirDIA_SN19.8_nf_DIA"
	
	FASTA = "${launchDir}/uniprotkbHUMAN20240104.bgsfasta"

	LIB_IN = "${params.psar_lib}/${params.JOB_NAME}.kit" // set the path to input library for dia analysis
	
	sample_size = null

	batch_size = 3
	
	// Define the string pattern of those rawfile to be excluded
	excludePattern = 'pooled'

	EXT_PSAR = "${launchDir}/null"
	
	// PROP_SEARCH = "${launchDir}/Astral_SILAC_MMCC.prop"

	// PROP_LIB = "${launchDir}/lib_gen.prop" // this one does not work for reasons I don't understand (TODO) but not needed imminently

	//DIA Analysis and direcDIA (inc. extended) workflow properties will be added via -s flag. Same command line option but need to be exported from correct tab in spectronaut
	PROP_DIA= "${launchDir}/null" // "${launchDir}/Astral_SILAC_MMCC.prop"

	//Condition setup. If you want statistics to be calculated then add condition setup file. A .tsv template can be exported from spectronaut gui.
	COND_SETUP= "${launchDir}/null" // "${launchDir}/ConditionSetup2.tsv"
	
	// if you want automatic report generation then add a template here (*.rs)
	REPORT= "${launchDir}/null" // "${launchDir}/PrecursorFragmentInfo.rs"

	// If total number of rawfiles cross this cutoff, the pipeline will execute CombineSNE process in place of ManageSNE.
	// Users can change this value based on their available HPC/Cloud resource to run large set of SNE file merging.
	max_files_for_ManageSNE = 150
}

log {
    file = '${params.log_dir}/${params.JOB_NAME}.log'
    level = 'INFO'
}

trace.enabled    = true
trace.file       = "${params.log_dir}/trace.txt"
trace.overwrite  = true

timeline.enabled = true
timeline.file    = "${params.log_dir}/timeline.html"
timeline.overwrite = true

report.enabled   = true
report.file      = "${params.log_dir}/report.html"
report.overwrite = true

dag.enabled      = true
dag.file         = "${params.log_dir}/flowchart.png"
dag.overwrite    = true

manifest {

    name	= 'Spectronaut-nf'
    author	= 'Collins_lab'
    homePage	= 'https://github.com/BenCollinsLab/Spectronaut-nf'
    description	= 'Execute Multiple Spectronaut Searches to High-Performance Cluster nodes'
    mainScript	= 'main.nf'
    nextflowVersion	= '25.10.3'
    version	= 'v1.2.0'

}

