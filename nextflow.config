// nextflow.config

process {

        withLabel: 'random_sampling' {
		executor = 'local'
                queue = 'k2-hipri'
                cpus = 4
                memory = '4 GB'
                time = '03:00:00'
                nodes = 1
                labels = 'SN-nf'
                errorStrategy = 'retry'
        }

        executor = 'slurm'

        withLabel: 'SN19_nf_lib' {
                queue = 'k2-hipri'
                cpus = 64
                memory = '128 GB'
                time = '03:00:00'
                nodes = 1
                labels = 'SN-nf'
                errorStrategy = 'retry'
		maxRetries = 3
		retryDelay = '5m'
        }

        withLabel: 'SN19_nf_combine_lib' {
                queue = 'k2-hipri'
                cpus = 32
                memory = '256 GB'
                time = '3:00:00'
                nodes = 1
                labels = 'SN-nf'
                errorStrategy = 'retry'
		maxRetries = 2
                retryDelay = '5m'
        }

        withLabel: 'SN19_nf_dia_search' {
                queue = 'k2-hipri'
                cpus = 64
                memory = '128 GB'
                time = '03:00:00'
                nodes = 1
                labels = 'SN-nf'
                errorStrategy = 'retry'
		maxRetries = 3
	        retryDelay = '5m'
        }

        withLabel: 'SN19_nf_combine_sne' {
                queue = 'k2-hipri'
                cpus = 32
                memory = '256 GB'
                time = '3:00:00'
                nodes = 1
                labels = 'SN-nf'
                errorStrategy = 'retry'
		maxRetries = 3
                retryDelay = '5m'
        }
}

executor {
	queueSize = 8
	submitRateLimit = '1/5sec'
}

params {
	SPEC_VER= "19.5.241126.62635"
	license = '***REMOVED***'
	spec_bin = "/users/3054755/bin/spectronaut/Spectronaut_$SPEC_VER/binaries/Spectronaut/bin/SpectronautCMD.dll"
	
	baseDir = "${baseDir}"
	rawfile_dir = "${baseDir}/raw_d"
	lib_output = "${baseDir}/out_lib"
	dia_output = "${baseDir}/out_dia"
	tmp_dir = "${baseDir}/tmp"
	log_dir	= "${baseDir}/logs"
	psar_lib = "${lib_output}/libs"
	
	JOB = "250127_Niamh_THP1_MZ1_SN_nf_DIA"
	
	FASTA = "${baseDir}/uniprotkbHUMAN20240104.bgsfasta"

	LIB_IN = "${psar_lib}/${JOB}.kit" // set the path to input library for dia analysis
	
	sample_size = 8

	batch_size = 2
	
	// excludePattern = 'pooled'  // Define the string pattern of those rawfile to be excluded

	// EXT_PSAR = psar_lib
	
	//Condition setup. If you want statistics to be calculated then add condition setup file. A .tsv template can be exported from spectronaut gui.
	COND_SETUP= "${baseDir}/ConditionSetup2.tsv"
	
	//If you want automatic report generation then add a template here (*.rs)
	REPORT= "${baseDir}/PrecursorFragmentInfo.rs"
	
	// PROP_SEARCH = "${baseDir}/Astral_SILAC_MMCC.prop"

	// PROP_LIB = "${baseDir}/lib_gen.prop" // this one does not work for reasons I don't understand (TODO) but not needed imminently

	//DIA Analysis and direcDIA (inc. extended) workflow properties will be added via -s flag. Same command line option but need to be exported from correct tab in spectronaut
	// PROP_DIA= "${baseDir}/Astral_SILAC_MMCC.prop"
}

log {
    file = '${params.JOB}.log'
    level = 'INFO'
}

manifest {

    name	= 'Spectronaut-nf'
    author	= 'Collins_lab'
    homePage	= 'https://github.com/BenCollinsLab/Spectronaut-nf'
    description	= 'Execute Multiple Spectronaut Searches to High-Performance Cluster nodes'
    mainScript	= 'main.nf'
    nextflowVersion	= '24.10.4'
    version	= 'v1.0.0'

}

